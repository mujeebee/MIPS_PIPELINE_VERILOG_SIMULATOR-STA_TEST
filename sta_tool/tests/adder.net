# Test 1: Simple 2-bit ripple carry adder
# Critical path: A[0] → XOR → AND → OR → sum[1]
clock_period 500

input  A0 B0 A1 B1 Cin
output Sum0 Sum1 Cout

# Bit 0
gate XOR2  xor0   A0 B0     ->  n_xor0
gate AND2  and0   A0 B0     ->  n_and0
gate XOR2  xor0b  n_xor0 Cin ->  Sum0
gate AND2  and0b  n_xor0 Cin ->  n_and0b
gate OR2   or0    n_and0 n_and0b  ->  Carry1

# Bit 1
gate XOR2  xor1   A1 B1      ->  n_xor1
gate AND2  and1   A1 B1      ->  n_and1
gate XOR2  xor1b  n_xor1 Carry1 ->  Sum1
gate AND2  and1b  n_xor1 Carry1 ->  n_and1b
gate OR2   or1    n_and1 n_and1b  ->  Cout
